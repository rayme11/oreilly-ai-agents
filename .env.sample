# API keys used across the notebooks. Copy this file to `.env` and fill in
# only the keys for the notebooks you intend to run.
#
#   cp .env.sample .env
#
# `.env` is gitignored, so your real keys stay out of version control.

# --- Most commonly used ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Other LLM providers (per-notebook) ---
GEMINI_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
MOONSHOT_API_KEY=

# --- Search / tools ---
SERPAPI_API_KEY=
SERP_API_KEY=
FIRECRAWL_API_KEY=

# --- Hugging Face (SmolAgents, datasets, local models) ---
HF_TOKEN=

# --- Google ADK / Vertex (path to service-account JSON) ---
GOOGLE_CREDENTIALS=
